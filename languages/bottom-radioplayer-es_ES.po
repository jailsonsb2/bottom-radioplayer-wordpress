msgstr "General"

#: includes/class-brp-settings-page.php:83
#: includes/class-brp-settings-page.php:104
msgid "Stations"
msgstr "Estaciones"

#: includes/class-brp-settings-page.php:84
msgid "Appearance"
msgstr "Apariencia"

#: includes/class-brp-settings-page.php:93
msgid "Bottom Radio Player"
msgstr "Bottom Radio Player"

#: includes/class-brp-settings-page.php:96
msgid "Settings saved."
msgstr "Configuración guardada."

#. translators: %s: link to the Stations tab
#: includes/class-brp-settings-page.php:103
msgid "The player will not appear on your site until you add at least one station with a stream URL, on the %s tab."
msgstr "El reproductor no aparecerá en tu sitio hasta que agregues al menos una estación con una URL de transmisión, en la pestaña %s."

#: includes/class-brp-settings-fields.php:22
msgid "Seamless navigation"
msgstr "Navegación seamless"

#: includes/class-brp-settings-fields.php:26
msgid "Keep the audio playing while visitors navigate between pages (recommended)."
msgstr "Mantiene el audio reproduciéndose mientras los visitantes navegan entre páginas (recomendado)."

#: includes/class-brp-settings-fields.php:31
msgid "Now-playing refresh interval (ms)"
msgstr "Intervalo de actualización de la canción actual (ms)"

#: includes/class-brp-settings-fields.php:34
msgid "How often the player polls for the current track. Minimum 3000ms."
msgstr "Con qué frecuencia el reproductor consulta la canción actual. Mínimo 3000ms."

#: includes/class-brp-settings-fields.php:48
msgid "Custom CSS"
msgstr "CSS personalizado"

#: includes/class-brp-settings-fields.php:51
msgid "Raw CSS printed on every front-end page, after the player's default styles — use it to override colors, spacing, fonts, etc."
msgstr "CSS sin procesar que se imprime en cada página del sitio, después de los estilos predeterminados del reproductor — úsalo para sobrescribir colores, espaciados, fuentes, etc."

#. translators: 1: #app-player selector, 2: --accent CSS variable, 3: link to the selector reference
#: includes/class-brp-settings-fields.php:56
msgid "Scope your rules under %1$s so they don't leak into the rest of the site. The dominant color extracted from the cover art is exposed as the %2$s CSS variable. Full selector reference and examples: %3$s."
msgstr "Escribe tus reglas dentro de %1$s para que no se filtren al resto del sitio. El color dominante extraído de la portada está disponible en la variable CSS %2$s. Referencia completa de selectores y ejemplos: %3$s."

#: includes/class-brp-settings-fields.php:61
msgid "Add one or more stations. Visitors can switch between them from the player's station list."
msgstr "Agrega una o más estaciones. Los visitantes pueden cambiar entre ellas desde la lista de estaciones del reproductor."

#: includes/class-brp-settings-fields.php:74
msgid "+ Add station"
msgstr "+ Agregar estación"

#: includes/class-brp-settings-fields.php:110
msgid "New station"
msgstr "Nueva estación"

#: includes/class-brp-settings-fields.php:111
msgid "Remove station"
msgstr "Eliminar estación"

#: includes/class-brp-settings-fields.php:116
msgid "Name"
msgstr "Nombre"

#: includes/class-brp-settings-fields.php:121
msgid "Hash (unique ID)"
msgstr "Hash (ID único)"

#: includes/class-brp-settings-fields.php:126
msgid "Description"
msgstr "Descripción"

#: includes/class-brp-settings-fields.php:132
msgid "Logo image"
msgstr "Imagen del logo"

#: includes/class-brp-settings-fields.php:133
msgid "Album art"
msgstr "Portada del álbum"

#: includes/class-brp-settings-fields.php:134
msgid "Background cover"
msgstr "Imagen de fondo"

#: includes/class-brp-settings-fields.php:141
msgid "Choose image"
msgstr "Elegir imagen"

#: includes/class-brp-settings-fields.php:141
msgid "Select an image"
msgstr "Selecciona una imagen"

#: includes/class-brp-settings-fields.php:147
msgid "Stream URL"
msgstr "URL de transmisión"

#: includes/class-brp-settings-fields.php:152
msgid "Now-playing API URL (optional)"
msgstr "URL de la API de canción actual (opcional)"

#: includes/class-brp-settings-fields.php:157
msgid "Live video stream URL (optional)"
msgstr "URL de transmisión de video en vivo (opcional)"

#: includes/class-brp-settings-fields.php:160
msgid "Embeddable player URL for a 24/7 video simulcast (opens in a \"Tv\" button). This is unrelated to the automatic \"Clipe\" button, which appears on its own whenever the now-playing API returns a YouTube ID for the current song."
msgstr "URL de reproductor incorporable para una transmisión de video 24/7 (se abre en un botón \"Tv\"). Esto no tiene relación con el botón automático \"Clipe\", que aparece por sí solo cuando la API de canción actual devuelve un ID de YouTube para la canción que suena."

#: includes/class-brp-settings-fields.php:163
msgid "Metadata source (optional)"
msgstr "Fuente de metadatos (opcional)"

#: includes/class-brp-settings-fields.php:169
msgid "Social links (optional)"
msgstr "Enlaces de redes sociales (opcional)"
